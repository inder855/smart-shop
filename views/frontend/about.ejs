<%- include('./partials/header', {title: 'About Us'}) %>

<!-- Hero Banner -->
<section class="hero-section py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="display-4 fw-bold mb-4">About Smart Shop</h1>
                <p class="lead mb-4">Your trusted destination for quality products at unbeatable prices. We're committed to providing the best shopping experience.</p>
                <p>Founded in 2024, Smart Shop has grown from a small local store to a comprehensive online marketplace. Our mission is to make quality products accessible to everyone while maintaining exceptional customer service.</p>
            </div>
            <div class="col-md-6 text-center">
                <img src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=600&h=400&fit=crop" class="img-fluid rounded" alt="About Us" onerror="this.src='https://via.placeholder.com/600x400/667eea/ffffff?text=About+Us'">
            </div>
        </div>
    </div>
</section>

<div class="container py-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-4">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">About Us</li>
        </ol>
    </nav>

    <!-- Mission & Vision -->
    <div class="row mb-5">
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-center mb-3">
                        <i class="bi bi-bullseye fs-1 text-primary"></i>
                    </div>
                    <h3 class="card-title text-center mb-3">Our Mission</h3>
                    <p class="card-text">To provide our customers with high-quality products at competitive prices while delivering exceptional customer service. We strive to make shopping convenient, enjoyable, and accessible to everyone.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-center mb-3">
                        <i class="bi bi-eye fs-1 text-primary"></i>
                    </div>
                    <h3 class="card-title text-center mb-3">Our Vision</h3>
                    <p class="card-text">To become the most trusted and preferred online shopping destination by continuously innovating, expanding our product range, and maintaining the highest standards of quality and service.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Our Values -->
    <section class="py-5 bg-light rounded mb-5">
        <div class="container">
            <h2 class="text-center mb-5">Our Values</h2>
            <div class="row g-4">
                <div class="col-md-3">
                    <div class="text-center">
                        <i class="bi bi-shield-check fs-1 text-primary mb-3"></i>
                        <h5>Quality</h5>
                        <p class="text-muted">We only offer products that meet our strict quality standards.</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="text-center">
                        <i class="bi bi-currency-rupee fs-1 text-primary mb-3"></i>
                        <h5>Affordability</h5>
                        <p class="text-muted">Competitive pricing without compromising on quality.</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="text-center">
                        <i class="bi bi-people fs-1 text-primary mb-3"></i>
                        <h5>Customer First</h5>
                        <p class="text-muted">Our customers are at the heart of everything we do.</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="text-center">
                        <i class="bi bi-lightning-charge fs-1 text-primary mb-3"></i>
                        <h5>Innovation</h5>
                        <p class="text-muted">Continuously improving and adapting to customer needs.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats -->
    <section class="py-5 mb-5" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
        <div class="container">
            <div class="row text-center">
                <div class="col-md-3 mb-4">
                    <h2 class="display-4 fw-bold">10K+</h2>
                    <p class="mb-0">Happy Customers</p>
                </div>
                <div class="col-md-3 mb-4">
                    <h2 class="display-4 fw-bold">5000+</h2>
                    <p class="mb-0">Products</p>
                </div>
                <div class="col-md-3 mb-4">
                    <h2 class="display-4 fw-bold">50+</h2>
                    <p class="mb-0">Categories</p>
                </div>
                <div class="col-md-3 mb-4">
                    <h2 class="display-4 fw-bold">100%</h2>
                    <p class="mb-0">Satisfaction</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Team -->
    <section class="py-5">
        <div class="container">
            <h2 class="text-center mb-5">Meet Our Team</h2>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card text-center h-100 shadow-sm">
                        <div class="card-body">
                            <div class="mb-3">
                                <img src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=100&h=100&fit=crop" class="rounded-circle" alt="John Doe" onerror="this.src='https://via.placeholder.com/100'">
                            </div>
                            <h5 class="card-title">John Doe</h5>
                            <p class="card-text text-primary fw-semibold">CEO & Founder</p>
                            <p class="card-text small">Leading the vision and strategy of Smart Shop since 2024.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center h-100 shadow-sm">
                        <div class="card-body">
                            <div class="mb-3">
                                <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=100&h=100&fit=crop" class="rounded-circle" alt="Jane Smith" onerror="this.src='https://via.placeholder.com/100'">
                            </div>
                            <h5 class="card-title">Jane Smith</h5>
                            <p class="card-text text-primary fw-semibold">Operations Manager</p>
                            <p class="card-text small">Ensuring smooth operations and excellent customer service.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center h-100 shadow-sm">
                        <div class="card-body">
                            <div class="mb-3">
                                <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=100&h=100&fit=crop" class="rounded-circle" alt="Mike Johnson" onerror="this.src='https://via.placeholder.com/100'">
                            </div>
                            <h5 class="card-title">Mike Johnson</h5>
                            <p class="card-text text-primary fw-semibold">Head of Products</p>
                            <p class="card-text small">Curating the best products for our customers.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<%- include('./partials/footer') %>
